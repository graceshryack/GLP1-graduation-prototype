{
  "flows": [
    {
      "name": "First-Time User Onboarding",
      "steps": [
        {
          "action": "Taps Get Started",
          "screenId": "Onboarding_Welcome",
          "annotation": "Program overview"
        },
        {
          "action": "Enters name and age",
          "screenId": "Onboarding_NameAge",
          "annotation": ""
        },
        {
          "action": "Selects medication, duration, status",
          "screenId": "Onboarding_Medication",
          "annotation": ""
        },
        {
          "action": "Multi-selects reasons",
          "screenId": "Onboarding_WhyOffGLP1",
          "annotation": ""
        },
        {
          "action": "Enters weight, height, activity",
          "screenId": "Onboarding_BodyActivity",
          "annotation": ""
        },
        {
          "action": "Multi-selects goals",
          "screenId": "Onboarding_Goals",
          "annotation": ""
        },
        {
          "action": "Multi-selects pre-GLP-1 struggles",
          "screenId": "Onboarding_PreStruggles",
          "annotation": ""
        },
        {
          "action": "Ranked multi-select current struggles",
          "screenId": "Onboarding_CurrentStruggles",
          "annotation": "Shapes personalized block order"
        },
        {
          "action": "Selects experience level",
          "screenId": "Onboarding_StrengthTraining",
          "annotation": ""
        },
        {
          "action": "Rates 8 questions 1-5",
          "screenId": "Onboarding_AssessmentQ1",
          "annotation": "Baseline assessment"
        },
        {
          "action": "Reviews program, taps Start",
          "screenId": "Onboarding_PersonalizedProgram",
          "annotation": "Shows personalized roadmap"
        },
        {
          "action": "",
          "screenId": "Home_CGM_Active",
          "annotation": "Arrives at personalized dashboard"
        }
      ]
    },
    {
      "name": "Daily Hunger Check-In",
      "steps": [
        {
          "action": "Taps hunger CTA",
          "screenId": "Home_CGM_Active",
          "annotation": "Always visible"
        },
        {
          "action": "Rates hunger and fullness 1-5",
          "screenId": "HungerQuestionnaire",
          "annotation": "Named scale anchors"
        },
        {
          "action": "Sees feedback",
          "screenId": "HungerQuestionnaire",
          "annotation": "Glucose insight card + educational tip"
        }
      ]
    },
    {
      "name": "Hunger Coach — Reactive Session",
      "steps": [
        {
          "action": "Taps Talk to your coach",
          "screenId": "Home_CGM_Active",
          "annotation": ""
        },
        {
          "action": "Reviews glucose card, selects scenario",
          "screenId": "HungerCoach_Landing",
          "annotation": "10 scenarios in 3 categories"
        },
        {
          "action": "Answers branching questions",
          "screenId": "HungerCoach_Scenario_StillHungry",
          "annotation": "When ate, what ate, stomach vs mouth"
        },
        {
          "action": "Commits to strategy",
          "screenId": "HungerCoach_Scenario_StillHungry",
          "annotation": "Logged for tracking"
        },
        {
          "action": "Selects outcome",
          "screenId": "HungerCoach_Scenario_StillHungry",
          "annotation": "Paused/ate intentionally/satisfied/learn more"
        }
      ]
    },
    {
      "name": "Hunger Coach — Proactive Pre-Meal",
      "steps": [
        {
          "action": "Selects About to eat",
          "screenId": "HungerCoach_Landing",
          "annotation": "Proactive scenario"
        },
        {
          "action": "Assesses hunger level",
          "screenId": "HungerCoach_Scenario_AboutToEat",
          "annotation": "Level-specific advice"
        },
        {
          "action": "Starts 20-min meal timer",
          "screenId": "HungerCoach_Scenario_AboutToEat",
          "annotation": "Vagus nerve pacing"
        }
      ]
    },
    {
      "name": "Hunger Coach — HALT Check",
      "steps": [
        {
          "action": "Selects Not hungry but want to eat",
          "screenId": "HungerCoach_Landing",
          "annotation": ""
        },
        {
          "action": "HALT grid: selects emotional state",
          "screenId": "HungerCoach_Scenario_NotHungry",
          "annotation": "Hungry/Angry-Anxious/Lonely-Bored/Tired"
        }
      ]
    },
    {
      "name": "Hunger Coach — Body Scan",
      "steps": [
        {
          "action": "Selects Not sure if hungry",
          "screenId": "HungerCoach_Landing",
          "annotation": ""
        },
        {
          "action": "4-step guided body scan with timers",
          "screenId": "HungerCoach_Scenario_Unsure",
          "annotation": "Interoception exercise"
        }
      ]
    },
    {
      "name": "Hunger Coach — Mini Lesson",
      "steps": [
        {
          "action": "Selects Teach me about hunger",
          "screenId": "HungerCoach_Landing",
          "annotation": ""
        },
        {
          "action": "Browses 5 mini-lessons",
          "screenId": "HungerCoach_Scenario_TeachMe",
          "annotation": "Types of hunger, hunger scale, GLP-1 effects, satiation, glucose-hunger"
        }
      ]
    },
    {
      "name": "Explore Graduation Timeline",
      "steps": [
        {
          "action": "Taps graduation card",
          "screenId": "Home_CGM_Active",
          "annotation": ""
        },
        {
          "action": "Scrolls timeline, taps Block 1 dot",
          "screenId": "Toolkit_Main",
          "annotation": "16 dots in 8 blocks"
        },
        {
          "action": "Reviews goal and education",
          "screenId": "WeekDetail_Block1_Baseline",
          "annotation": "Baseline: observe and log"
        },
        {
          "action": "Reads article",
          "screenId": "Education_CGM_Basics",
          "annotation": "1-3 min read"
        }
      ]
    },
    {
      "name": "Post-Block-4 Check-In and Unlock",
      "steps": [
        {
          "action": "Taps locked Block 5",
          "screenId": "Toolkit_Main",
          "annotation": ""
        },
        {
          "action": "Taps Start your check-in",
          "screenId": "WeekDetail_Block5_Locked",
          "annotation": ""
        },
        {
          "action": "4-step flow",
          "screenId": "Assessment_Post8_Intro",
          "annotation": "Insights -> quiz -> feedback -> focus"
        },
        {
          "action": "",
          "screenId": "WeekDetail_Block5_Locked",
          "annotation": "Now unlocked with personalized content"
        }
      ]
    },
    {
      "name": "CGM Toggle Experience",
      "steps": [
        {
          "action": "Views live glucose graph",
          "screenId": "Home_CGM_Active",
          "annotation": "Blue border, LIVE badge"
        },
        {
          "action": "Taps toggle to CGM Off",
          "screenId": "Home_CGM_Off",
          "annotation": "Amber, average day graph, elevated coach"
        }
      ]
    },
    {
      "name": "Sensor Comparison in Insights",
      "steps": [
        {
          "action": "Views Lifestyle GPA and correlations",
          "screenId": "Insights_Lifestyle",
          "annotation": ""
        },
        {
          "action": "Taps Glucose tab, views sensor comparison",
          "screenId": "Insights_Glucose",
          "annotation": "Overlaid CGM period curves"
        },
        {
          "action": "Taps Graduation tab, views trend graph",
          "screenId": "Insights_Graduation",
          "annotation": "Week-by-week scores"
        }
      ]
    },
    {
      "name": "Body Scanner Flow",
      "steps": [
        {
          "action": "Taps Body Scanner",
          "screenId": "Log_Main",
          "annotation": ""
        },
        {
          "action": "Starts scan, waits 5s",
          "screenId": "BodyScanner",
          "annotation": "Mock analysis"
        },
        {
          "action": "Views results",
          "screenId": "BodyScanner",
          "annotation": "Body fat, visceral fat, lifestyle bonus"
        }
      ]
    },
    {
      "name": "Program Reset",
      "steps": [
        {
          "action": "Taps Reset program",
          "screenId": "Settings",
          "annotation": "Red card"
        },
        {
          "action": "Confirms in modal",
          "screenId": "Settings",
          "annotation": "Clears localStorage"
        },
        {
          "action": "",
          "screenId": "Onboarding_Welcome",
          "annotation": "Returns to step 0"
        }
      ]
    },
    {
      "name": "Education Game Flow",
      "steps": [
        {
          "action": "Taps Exercise section",
          "screenId": "Toolkit_Main",
          "annotation": ""
        },
        {
          "action": "Plays quiz rounds",
          "screenId": "Game_ProteinGuess",
          "annotation": "Compare foods"
        },
        {
          "action": "Builds a meal",
          "screenId": "Game_BuildBalancedPlate",
          "annotation": "Protein + carb + veggie"
        }
      ]
    }
  ],
